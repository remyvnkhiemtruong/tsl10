# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JWT_SECRET="change-this-super-secret-in-production-at-least-32-characters"
NODE_ENV="development"

# Database - local Docker development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vvk_admission?schema=public"

# Vercel / production database
# On Vercel, set DATABASE_URL in Project Settings > Environment Variables.
# If your provider gives a direct migration URL, keep it locally and use it when running prisma migrate deploy.
DIRECT_URL=""

# Storage provider: local or vercel_blob
# local is only for development. Vercel production should use vercel_blob.
STORAGE_PROVIDER="local"
UPLOAD_DIR=".data/uploads"
MAX_UPLOAD_MB="25"

# Vercel Blob - required when STORAGE_PROVIDER=vercel_blob
# Must stay private because admission files contain personal data.
BLOB_READ_WRITE_TOKEN=""
BLOB_ACCESS="private"

# Optional production migration switch for Vercel build.
# Recommended default: false. Run migrations manually unless you know what you are doing.
RUN_PRISMA_MIGRATE_DEPLOY="false"

# Seed admin - development only
SEED_ADMIN_EMAIL="admin@gmail.com"
SEED_ADMIN_PASSWORD="Admin123@"
